# SGNL Development Environment Configuration

# ============ API KEYS ============

# OpenAI API Key (required for GPT-4o analysis in /deep-scan and /scan-topic)
OPENAI_API_KEY=sk-dev-placeholder

# Tavily API Key (required for search via n8n workflow)
TAVILY_API_KEY=tvly-dev-placeholder

# ============ n8n WORKFLOWS ============

# n8n webhook URL for deep scan with LLM analysis
N8N_WEBHOOK_URL=http://n8n.metinkorkmaz.quest/webhook/sgnl/scan-topic

# n8n webhook URL for fast search (raw results only)
N8N_FAST_SEARCH_URL=http://n8n.metinkorkmaz.quest/webhook/fast-search

# ============ CORS CONFIGURATION ============

# CORS allowed origins (comma-separated URLs) - Allow local development
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============ RATE LIMITING ============

# Maximum requests per minute per IP (default: 100 for dev, 20 for prod)
RATE_LIMIT=100

# Time window in seconds for rate limiting (default: 60)
RATE_WINDOW_SECONDS=60

# ============ SERVER CONFIGURATION ============

# API server host (default: 0.0.0.0)
HOST=0.0.0.0

# API server port (default: 8000)
PORT=8000

# ============ LOGGING ============

# Log level: DEBUG, INFO, WARNING, ERROR (default: DEBUG for dev)
LOG_LEVEL=DEBUG

# ============ CONTENT EXTRACTION ============

# Content density threshold for skipping LLM (0.0-1.0, default: 0.45)
DENSITY_THRESHOLD=0.45

# Max content length to send to LLM (default: 12000)
LLM_MAX_CHARS=12000

# ============ REDIS CONFIGURATION ============

# Redis URL for distributed caching (service name 'redis' matches docker-compose)
REDIS_URL=redis://redis:6379/0
